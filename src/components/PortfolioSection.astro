---
import { portfolioFilters, portfolioProjects } from '../data/site';

const categoryClassMap = {
  client: 'filter-client',
  showcase: 'filter-showcase',
  starter: 'filter-starter',
} as const;
---

<section id="portfolio" class="portfolio section-bg">
  <div class="container" data-aos="fade-up">
    <div class="section-title">
      <h2>Portfolio</h2>
      <p>
        These projects are selected examples of my work, not the full list. Most of them are real client
        applications, while others are engineering starters or a technical showcase project built to demonstrate
        architecture, backend, and fullstack development skills. When available, you will find either a live
        application link or a GitHub repository. For confidential internal systems, only selected visuals and project
        summaries can be shared.
      </p>
    </div>

    <div class="row">
      <div class="col-lg-12 d-flex justify-content-center" data-aos="fade-up" data-aos-delay="100">
        <ul id="portfolio-flters">
          {
            portfolioFilters.map((filter, index) => (
              <li data-filter={filter.value} class:list={[index === 0 && 'filter-active']}>{filter.label}</li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="row portfolio-container" data-aos="fade-up" data-aos-delay="200">
      {
        portfolioProjects.map((project) => (
          <div class:list={['col-lg-4', 'col-md-6', 'portfolio-item', categoryClassMap[project.category]]}>
            <div class="portfolio-wrap">
              <img src={project.cardImage} class="img-fluid" alt={project.title} loading="lazy" decoding="async" />
              <div class="portfolio-info">
                <h4>{project.cardTitle}</h4>
                <p>{project.summary}</p>
                <div class="portfolio-links">
                  <a
                    href={`/projects/${project.slug}`}
                    class="portfolio-details-lightbox"
                    data-glightbox="type: external"
                    title={project.title}
                  >
                    <i class="bx bx-link"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
